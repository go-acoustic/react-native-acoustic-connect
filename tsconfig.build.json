{
  // Used by react-native-builder-bob's `typescript` target (see package.json)
  // so test files don't get .d.ts emitted into lib/typescript. `npm run
  // typecheck` still uses tsconfig.json, which includes the tests.
  // Note: `exclude` is replaced (not merged) by `extends`, so the base
  // entries are repeated here.
  "extends": "./tsconfig.json",
  "exclude": [
    "**/node_modules",
    "**/.eslintrc.js",
    "**/.prettierrc.js",
    "**/jest.config.js",
    "**/babel.config.js",
    "**/metro.config.js",
    "**/tsconfig.json",
    "src/**/__tests__/**"
  ]
}
